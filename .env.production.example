# =============================================================================
# Production Environment Configuration
# =============================================================================
# Copy this file to .env on your production server and fill in real values.
# NEVER commit .env with real credentials to version control.
# =============================================================================

# Application Settings
APP_NAME=Laravel
APP_ENV=production
APP_KEY=                        # Generate with: php artisan key:generate
APP_DEBUG=false                 # MUST be false in production
APP_URL=https://yourdomain.com  # Your actual production domain (HTTPS required)

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# =============================================================================
# Security
# =============================================================================
BCRYPT_ROUNDS=12                # 12 is recommended for production

# =============================================================================
# Logging
# =============================================================================
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning               # Use 'warning' or 'error' in production (not 'debug')

# =============================================================================
# Database
# =============================================================================
DB_CONNECTION=mysql              # Use mysql/pgsql for production
DB_HOST=127.0.0.1               # Your database host
DB_PORT=3306
DB_DATABASE=your_database_name
DB_USERNAME=your_database_user
DB_PASSWORD=your_secure_password # Use a strong, unique password

# =============================================================================
# Session
# =============================================================================
SESSION_DRIVER=redis             # Redis recommended for production (or 'database')
SESSION_LIFETIME=120
SESSION_ENCRYPT=true             # Encrypt sessions in production
SESSION_PATH=/
SESSION_DOMAIN=yourdomain.com    # Set to your actual domain
# SESSION_SECURE_COOKIE=true     # Uncomment if using HTTPS (recommended)

# =============================================================================
# Cache, Queue, and Broadcasting
# =============================================================================
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis           # Redis recommended for production
CACHE_STORE=redis                # Redis recommended for production
# CACHE_PREFIX=

# =============================================================================
# Redis
# =============================================================================
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null              # Set a password if Redis is exposed
REDIS_PORT=6379

# =============================================================================
# Mail (SMTP)
# =============================================================================
MAIL_MAILER=smtp
MAIL_SCHEME=tls                  # Use 'tls' for secure connections
MAIL_HOST=smtp.yourmailprovider.com
MAIL_PORT=587
MAIL_USERNAME=your-email@yourdomain.com
MAIL_PASSWORD=your-mail-password
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

# =============================================================================
# AWS (if applicable)
# =============================================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# =============================================================================
# Vite / Frontend
# =============================================================================
VITE_APP_NAME="${APP_NAME}"
